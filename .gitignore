# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# integration secrets
.integrations.json

# database
dev.db

# backfill de conversas — checkpoint/manifest gerados pelo --execute (runtime)
scripts/.backfill-conversas-checkpoint.json
scripts/.backfill-conversas-manifest.jsonl
dev.db-journal
.pglite-dev/

# editor/hook tmp backups
*.tmp.[0-9]*

# Claude Code agent worktrees (created by isolation: "worktree")
.claude/worktrees/
.claude/launch.json

# Migration backups (ad-hoc dumps locais, fora do controle de versao)
.migration-backups/
scripts/_btg-discovery-output.json
