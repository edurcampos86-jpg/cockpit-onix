generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

model User {
  id        String   @id @default(cuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  password  String
  role      String   @default("support") // "admin" | "support"
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts             Post[]
  scripts           Script[]
  tasks             Task[]
  leads             Lead[]
  prioridadesPainel PainelPrioridade[]
  acoesPainel       AcaoPainel[]
  cachesPainel      PainelCacheExterno[]
  syncRequests      SyncRequest[]
  painelSugestoes   PainelSugestao[]
  painelRetros     PainelRetrospectiva[]
  painelEmailsAI    PainelEmailAI[]
  pessoa            Pessoa?
}

// ============================================
// CALENDÁRIO EDITORIAL E CONTEÚDO
// ============================================

model Post {
  id            String   @id @default(cuid())
  title         String
  format        String   // "reel" | "story" | "carrossel"
  category      String   // "pergunta_semana" | "onix_pratica" | "patrimonio_mimimi" | "alerta_patrimonial" | "sabado_bastidores"
  status        String   @default("rascunho") // "rascunho" | "roteiro_pronto" | "gravado" | "editado" | "agendado" | "publicado"
  scheduledDate DateTime
  scheduledTime String?  // HH:mm
  publishedAt   DateTime?
  publishedUrl  String?
  ctaType       String?  // "explicito" | "implicito" | "identificacao"
  hashtags      String?  // comma-separated
  notes         String?
  order         Int      @default(0)
  googleCalendarEventId String? // ID do evento no Google Calendar
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  scriptId String? @unique
  script   Script? @relation(fields: [scriptId], references: [id])

  tasks Task[]
}

model Script {
  id              String   @id @default(cuid())
  title           String
  category        String
  hook            String?
  body            String
  cta             String?
  ctaType         String?
  estimatedTime   String?
  hashtags        String?
  isTemplate      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  post     Post?
  versions ScriptVersion[]
}

model ScriptVersion {
  id            String   @id @default(cuid())
  title         String
  hook          String?
  body          String
  cta           String?
  ctaType       String?
  estimatedTime String?
  hashtags      String?
  changeReason  String   @default("edição manual")
  createdAt     DateTime @default(now())

  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

// ============================================
// GESTÃO DE TAREFAS
// ============================================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pendente") // "pendente" | "em_progresso" | "concluida"
  priority    String   @default("media")
  dueDate     DateTime?
  completedAt DateTime?
  type        String   @default("geral")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assigneeId String
  assignee   User   @relation(fields: [assigneeId], references: [id])

  postId String?
  post   Post?   @relation(fields: [postId], references: [id])
}

// ============================================
// GESTÃO DE LEADS E FUNIL
// ============================================

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  origin          String   @default("manychat")
  stage           String   @default("novo")
  temperature     String   @default("morno")
  productInterest String?
  notes           String?
  lastContactAt   DateTime?
  enteredAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  meetings Meeting[]
}

// ============================================
// ONIX CORRETORA - TREINAMENTO COMERCIAL
// ============================================

model Relatorio {
  id                  String    @id @default(cuid())
  vendedor            String
  periodo             String
  periodoInicio       DateTime
  periodoFim          DateTime
  dataExecucao        DateTime
  conversasAnalisadas Int
  pdfPath             String?
  secao1              String    @db.Text
  secao2              String    @db.Text
  secao3              String    @db.Text
  secao4              String    @db.Text
  secao5              String    @db.Text
  secao0              String?   @db.Text
  scriptSemana        String?   @db.Text
  termometro          String?   @db.Text
  retomada            String?   @db.Text
  acoes               Acao[]
  metricas            Metrica?
  createdAt           DateTime  @default(now())

  @@index([vendedor])
  @@index([periodoInicio])
}

model Acao {
  id          String    @id @default(cuid())
  relatorioId String
  relatorio   Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)
  vendedor    String
  numero      Int
  titulo      String
  descricao   String    @db.Text
  concluida   Boolean   @default(false)
  concluidaEm DateTime?
  createdAt   DateTime  @default(now())

  @@index([relatorioId])
  @@index([vendedor, concluida])
}

model Metrica {
  id                   String    @id @default(cuid())
  relatorioId          String    @unique
  relatorio            Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)
  vendedor             String
  periodo              String
  conversasAnalisadas  Int
  conversasSemResposta Int       @default(0)
  reunioesAgendadas    Int       @default(0)
  leadsPerdidos        Int       @default(0)
  score                Int       @default(0)
  createdAt            DateTime  @default(now())

  @@index([vendedor, createdAt])
}

model RelatorioColetivo {
  id                  String   @id @default(cuid())
  periodo             String
  periodoInicio       DateTime
  periodoFim          DateTime
  dataExecucao        DateTime
  vendedoresAnalisados String  // "Thiago Vergal,Rose Oliveira"
  metricasConsolidadas String? @db.Text // JSON: totais + variações
  scoreIndividual      String? @db.Text // JSON: scores por vendedor
  termometroTime       String? @db.Text
  objecoesRecorrentes  String? @db.Text
  padroesPositivos     String? @db.Text
  padroesRisco         String? @db.Text
  scriptColetivo       String? @db.Text
  planoColetivo        String? @db.Text
  cumprimentoAnterior  String? @db.Text
  createdAt            DateTime @default(now())

  @@index([periodoInicio])
}

model Meta {
  id        String   @id @default(cuid())
  vendedor  String
  metrica   String   // "conversas" | "reunioes" | "semResposta" | "perdidos" | "score"
  valor     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendedor, metrica])
}

// ============================================
// REUNIÕES E TRANSCRIÇÕES (Plaud.ai via Zapier)
// ============================================

model Meeting {
  id            String   @id @default(cuid())
  title         String
  date          DateTime
  duration      Int?     // minutos
  participants  String?  // nomes separados por vírgula
  vendedor      String?  // vendedor da equipe Onix (Eduardo Campos | Thiago Vergal | Rose Oliveira)
  transcription String?  @db.Text // transcrição completa
  summary       String?  // resumo gerado pela IA
  actionItems   String?  // itens de ação extraídos (JSON)
  insights      String?  // insights para roteiros (gerado pela Claude AI)
  source        String   @default("plaud") // "plaud" | "manual" | "zoom" | "teams"
  externalId    String?  // ID do Plaud/Zapier
  audioUrl      String?  // URL do áudio original
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  @@index([vendedor, date])
}

// ============================================
// CONFIGURAÇÕES DINÂMICAS (fallback p/ env vars)
// ============================================

model Config {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================
// ANALYTICS E FEEDBACK LOOP
// ============================================

model InstagramPost {
  id                  String   @id @default(cuid())
  instagramId         String   @unique
  type                String   // "VIDEO" | "CAROUSEL_ALBUM" | "IMAGE"
  caption             String?
  permalink           String?
  pilar               String?  // "P1" | "P2" | "P3" | "P4"
  formato             String?  // "reel" | "carrossel" | "imagem" | "stories"
  ctaType             String?  // "explicito" | "implicito" | "identificacao" | "algoritmo"
  tema                String?  // tema central da semana
  likes               Int      @default(0)
  comments            Int      @default(0)
  shares              Int      @default(0)
  saved               Int      @default(0)
  reach               Int      @default(0)
  views               Int      @default(0)
  totalInteractions   Int      @default(0)
  engagementRate      Float    @default(0) // (totalInteractions / reach) * 100
  saveRate            Float    @default(0) // (saved / reach) * 100
  publishedAt         DateTime
  insightsCollectedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WeeklyAnalysis {
  id              String   @id @default(cuid())
  weekStart       DateTime
  weekEnd         DateTime
  totalPosts      Int      @default(0)
  newFollowers    Int      @default(0)
  lostFollowers   Int      @default(0)
  totalFollowers  Int      @default(0)
  metricas        String   // JSON: métricas por pilar/formato/CTA
  descobertas     String   // JSON: array de descobertas
  recomendacoes   String   // JSON: array de recomendações
  proximosTemas   String?  // JSON: temas sugeridos para próximas semanas
  geradoPor       String   @default("manual") // "automatico" | "manual"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recommendations Recommendation[]
}

model Recommendation {
  id              String   @id @default(cuid())
  tipo            String   // "pilar" | "formato" | "cta" | "horario" | "frequencia" | "tema"
  titulo          String
  descricao       String
  acao            String
  impactoEsperado String?
  prioridade      String   @default("media") // "alta" | "media" | "baixa"
  status          String   @default("pendente") // "pendente" | "implementada" | "descartada"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  weeklyAnalysisId String?
  weeklyAnalysis   WeeklyAnalysis? @relation(fields: [weeklyAnalysisId], references: [id])

  scriptAdjustments ScriptAdjustment[]
}

model ScriptAdjustment {
  id               String   @id @default(cuid())
  scriptId         String?
  ajuste           String   // Descrição do ajuste feito
  motivacao        String   // Por que foi feito
  statusAntes      String?  // Conteúdo antes do ajuste
  statusDepois     String?  // Conteúdo depois do ajuste
  aplicado         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id])
}

// ============================================
// PAINEL SEMANAL — METAS E PIPELINE
// ============================================

model MetaMensal {
  id               String   @id @default(cuid())
  mes              Int      // 1-12
  ano              Int
  metaFaturamento  Float    // valor da meta mensal em R$
  faturamentoAtual Float    @default(0) // faturamento acumulado no mês
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  @@unique([mes, ano])
}

model NegocioPipeline {
  id              String    @id @default(cuid())
  nomeCliente     String
  valor           Float     // valor do negócio em R$
  responsavel     String    // nome do vendedor
  etapa           String    // etapa no pipeline
  ultimaAtividade DateTime  // data da última atividade registrada
  externalId      String?   @unique // ID no CRM Datacrazy (futura integração)
  ativo           Boolean   @default(true)
  motivoPerda     String?   // "preco" | "timing" | "concorrencia" | "atendimento" | "outro"
  dataPerda       DateTime? // quando foi marcado como adormecido
  dataRecontato   DateTime? // agenda de recontato (dataPerda + 60 dias)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  resolucoes      AlertaResolucao[]

  @@index([ativo, ultimaAtividade])
  @@index([etapa])
}

// ============================================
// ALERTAS DE PIPELINE
// ============================================

model AlertaResolucao {
  id          String   @id @default(cuid())
  negocioId   String
  negocio     NegocioPipeline @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  tipo        String   // "parado_48h" | "alto_ticket" | "reativacao_60d"
  acaoTomada  String   @db.Text
  resolvidoEm DateTime @default(now())

  @@index([negocioId])
}

// ============================================
// RITUAIS DE GESTÃO
// ============================================

model RitualExecucao {
  id        String   @id @default(cuid())
  ritualId  String   // ID do ritual (micro-coaching, reuniao-segunda, etc.)
  data      DateTime // data da ocorrência
  realizado Boolean  @default(false)
  notas     String?  @db.Text
  criadoEm  DateTime @default(now())

  @@unique([ritualId, data])
  @@index([ritualId])
  @@index([data])
}

// ============================================
// BACKOFFICE — DADOS DE CLIENTES
// ============================================

// ============================================
// BACKOFFICE — CLIENTES (modelo Supernova 12-4-2)
// ============================================

model ClienteBackoffice {
  id            String   @id @default(cuid())
  nome          String
  numeroConta   String
  saldo         Float    @default(0)
  saldoConta    Float    @default(0) // Saldo em conta corrente (cash disponível) — via BTG

  // Classificação ABC (Supernova)
  // A = top clientes (12 contatos/ano), B = relacionamento ativo, C = manutenção
  classificacao String   @default("C") // "A" | "B" | "C"
  classificacaoManual Boolean @default(false) // true = travada, não recalcular

  // Contato e relacionamento
  email         String?
  telefone      String?
  aniversario   DateTime?
  profissao     String?
  nicho         String?  // "medico" | "empresario" | "executivo" | "outro"

  // Storyselling / perfil emocional
  perfilEmocional String? @db.Text // medos, sonhos, linguagem preferida
  observacoes     String? @db.Text

  // Cadência e promessa de serviço
  ultimoContatoAt DateTime?
  proximoContatoAt DateTime?

  // Receita
  receitaAnual  Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  interacoes  InteracaoCliente[]
  metas       MetaCliente[]
  eventosVida EventoVida[]
  indicacoes  Indicacao[] @relation("ClienteIndicador")
  perfilDescoberta PerfilDescoberta?
  planoUmaPagina   PlanoUmaPagina?
  checklist        ChecklistOrganizacao?
  acoesVinculadas  AcaoPainel[] @relation("AcaoCliente")

  @@index([numeroConta])
  @@index([classificacao])
  @@index([proximoContatoAt])
}

// Registro de cada contato: 12-4-2 (12 ligações, 4 reuniões, 2 revisões por ano para clientes A)
model InteracaoCliente {
  id          String   @id @default(cuid())
  clienteId   String
  cliente     ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo        String   // "ligacao" | "reuniao" | "revisao" | "email" | "whatsapp" | "evento"
  canal       String?  // "telefone" | "presencial" | "videoconferencia" | "email" | "whatsapp"
  assunto     String
  resumo      String?  @db.Text
  data        DateTime @default(now())
  duracaoMin  Int?

  // Roteiro RCA (Rapid Client Assessment)
  rcaNotas    String?  @db.Text

  criadoEm    DateTime @default(now())

  @@index([clienteId, data])
  @@index([tipo])
}

// Mapa de metas de vida do cliente
model MetaCliente {
  id         String   @id @default(cuid())
  clienteId  String
  cliente    ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  titulo     String
  descricao  String?  @db.Text
  prazoData  DateTime?
  valorAlvo  Float?
  status     String   @default("ativa") // "ativa" | "atingida" | "pausada" | "cancelada"
  categoria  String?  // "aposentadoria" | "educacao" | "imovel" | "viagem" | "outro"

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([clienteId])
}

// Eventos de vida (aniversários, casamentos, nascimentos)
model EventoVida {
  id         String   @id @default(cuid())
  clienteId  String
  cliente    ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo       String   // "aniversario" | "casamento" | "nascimento" | "formatura" | "outro"
  titulo     String
  data       DateTime
  recorrente Boolean  @default(false)
  lembrar    Boolean  @default(true)
  notas      String?  @db.Text

  criadoEm   DateTime @default(now())

  @@index([data])
  @@index([clienteId])
}

// CRM de indicações (referrals)
model Indicacao {
  id              String   @id @default(cuid())

  // Quem indicou (cliente existente)
  indicadorId     String?
  indicador       ClienteBackoffice? @relation("ClienteIndicador", fields: [indicadorId], references: [id])

  // Indicado (prospect)
  nomeIndicado    String
  emailIndicado   String?
  telefoneIndicado String?

  status          String   @default("recebida") // "recebida" | "contatada" | "reuniao" | "convertida" | "perdida"
  valorEstimado   Float?
  agradecimentoEnviado Boolean @default(false)
  notas           String?  @db.Text

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([status])
}

// Questionário de descoberta profunda (Storyselling — hemisfério direito)
model PerfilDescoberta {
  id          String   @id @default(cuid())
  clienteId   String   @unique
  cliente     ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  valoresVida       String? @db.Text // o que mais importa
  medos             String? @db.Text // medos financeiros / pesadelos
  sonhos            String? @db.Text // o que faria se dinheiro não fosse problema
  legado            String? @db.Text // o que quer deixar para a próxima geração
  experienciaPrev   String? @db.Text // experiências passadas com investimentos
  linguagemPref     String? // "tecnica" | "simples" | "visual" | "narrativa"
  mentorReferencia  String? @db.Text // quem o cliente admira financeiramente
  familiaSituacao   String? @db.Text // composição familiar e dependentes
  perguntaMagica    String? @db.Text // resposta à "se tudo desse certo, como seria daqui a 5 anos?"

  atualizadoEm DateTime @updatedAt
  criadoEm     DateTime @default(now())
}

// One-Page Financial Plan (Supernova)
model PlanoUmaPagina {
  id          String   @id @default(cuid())
  clienteId   String   @unique
  cliente     ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  visaoFamiliar     String? @db.Text
  objetivoPrincipal String? @db.Text
  horizonteAnos     Int?
  perfilRisco       String? // "conservador" | "moderado" | "arrojado"
  alocacaoAlvo      String? @db.Text // ex: "60% RF / 30% RV / 10% alternativos"
  riscosPrincipais  String? @db.Text
  proximosPassos    String? @db.Text
  resumoExecutivo   String? @db.Text

  atualizadoEm DateTime @updatedAt
  criadoEm     DateTime @default(now())
}

// Checklist de organização financeira
model ChecklistOrganizacao {
  id          String   @id @default(cuid())
  clienteId   String   @unique
  cliente     ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  testamento           Boolean @default(false)
  seguroVida           Boolean @default(false)
  planoSucessao        Boolean @default(false)
  reservaEmergencia    Boolean @default(false)
  planoSaude           Boolean @default(false)
  procuracao           Boolean @default(false)
  inventarioBens       Boolean @default(false)
  beneficiariosAtual   Boolean @default(false)
  declaracaoIR         Boolean @default(false)
  planejamentoTributario Boolean @default(false)
  notas                String? @db.Text

  atualizadoEm DateTime @updatedAt
  criadoEm     DateTime @default(now())
}

// Biblioteca de histórias/analogias para storyselling
model StoryAnalogia {
  id         String   @id @default(cuid())
  titulo     String
  categoria  String   // "aposentadoria" | "sucessao" | "risco" | "diversificacao" | "inflacao" | "disciplina"
  analogia   String   @db.Text
  quandoUsar String?  @db.Text
  tags       String?  // comma-separated

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([categoria])
}

// Lançamentos de receita por parceiro/produto/cliente (importados via planilha BTG)
model ReceitaItem {
  id            String   @id @default(cuid())
  data          DateTime
  faturamento   Float    @default(0)
  imposto       Float    @default(0)
  faturamentoLiquido Float @default(0)
  assessor      String?
  parceiro      String?
  departamento  String?
  classificacao String?
  categoria     String?
  produto       String?
  nomeCliente   String?
  loteId        String   // identifica a importação (para limpar/refazer)
  hash          String?  @unique // dedupe: data+valores+parceiro+produto+cliente+assessor
  criadoEm      DateTime @default(now())

  @@index([data])
  @@index([parceiro])
  @@index([produto])
  @@index([nomeCliente])
  @@index([loteId])
}

// ============================================
// PAINEL DO DIA
// ============================================

// 3 prioridades manuais por dia (posicao 1|2|3)
model PainelPrioridade {
  id         String   @id @default(cuid())
  userId     String
  data       String   // "YYYY-MM-DD" em America/Sao_Paulo
  posicao    Int      // 1, 2 ou 3
  texto      String
  concluida  Boolean  @default(false)

  // Sug 1 (Boot do Dia): prioridade sugerida automaticamente pela heurística
  // noturna. Eduardo confirma/edita no painel.
  sugeridaPorBoot Boolean @default(false)
  bootMotivo      String? // ex: "cliente A sem contato ha 27 dias"

  // Sug 2 (Deep Work blocks): tempo estimado para a prioridade + id do bloco
  // de foco criado no calendario (Outlook/Google)
  tempoEstimadoMin    Int?
  focusBlockEventId   String?   // id do evento no calendario externo
  focusBlockProvider  String?   // "google" | "ms-calendar" | "pending-cowork"
  focusBlockStart     DateTime?
  focusBlockEnd       DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data, posicao])
  @@index([userId, data])
}

// Acoes unificadas do painel: local (cockpit) + MS To Do + Priority Matrix
// Write-back bidirecional via cowork (Chrome MCP): pendingSync=true dispara
// aplicação na origem na próxima sincronia.
model AcaoPainel {
  id          String    @id @default(cuid())
  userId      String
  titulo      String
  concluida   Boolean   @default(false)
  vence       DateTime?
  importante  Boolean   @default(false)
  noMeuDia    Boolean   @default(false)
  quadrante   String?   // "Q1" | "Q2" | "Q3" | "Q4" (só Priority Matrix)
  origem      String    // "cockpit" | "ms-todo" | "priority-matrix"
  externoId   String?   // id na fonte externa (preenchido após sync)
  projetoPm   String?   // nome do projeto no Priority Matrix
  pendingSync Boolean   @default(false)
  syncOp      String?   // "create" | "update" | "delete"
  syncError   String?

  // Fecho de atividade (Sugestao 4: modal de encerramento)
  resultado        String?  @db.Text // o que foi entregue / nota livre
  tempoGastoMin    Int?              // tempo gasto em minutos
  clienteVinculadoId String?         // FK opcional para ClienteBackoffice
  concluidaEm      DateTime?         // timestamp do fecho (distinto de updatedAt)
  registradaCrm    Boolean  @default(false) // true se virou InteracaoCliente

  // Sug 2 (Deep Work): tempo estimado para execução — alimenta auto-blocking
  tempoEstimadoMin Int?

  // Sug 4 (Triagem AI de e-mails): origem foi um e-mail classificado pela IA
  criadaDeEmailId  String? // id do PainelEmailAI que gerou a acao

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clienteVinculado ClienteBackoffice? @relation("AcaoCliente", fields: [clienteVinculadoId], references: [id], onDelete: SetNull)

  @@index([userId, concluida])
  @@index([userId, origem])
  @@index([userId, pendingSync])
  @@index([clienteVinculadoId])
}

// Cache de leitura das fontes externas sem write-back (Calendar + Mail).
// Um registro por (user, source) — payload é substituído a cada sync.
model PainelCacheExterno {
  id       String   @id @default(cuid())
  userId   String
  source   String   // "ms-calendar" | "ms-mail"
  payload  Json
  syncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId])
}

// Fila de pedidos de sync do usuario pro cowork (Chrome MCP).
// O usuario aperta "Sincronizar" no painel -> cria um registro pending.
// Quando o Claude Code roda na maquina dele, checa a fila, processa,
// marca como done/error.
model SyncRequest {
  id          String    @id @default(cuid())
  userId      String
  sources     String    // "all" | "microsoft" | "priority-matrix"
  status      String    @default("pending") // "pending" | "in-progress" | "done" | "error"
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  error       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, requestedAt])
}

// Sug 3 (Auto-encerramento): sugestões geradas por automação que aparecem
// como cards de ação rápida no painel. Ex.: "Encerrar reunião com Onix Corretora
// que terminou há 30min". Eduardo aceita, adia ou ignora.
model PainelSugestao {
  id         String   @id @default(cuid())
  userId     String
  tipo       String   // "encerrar-reuniao" | "cliente-fora-cadencia" | "acao-zumbi"
  titulo     String
  descricao  String?  @db.Text
  payload    Json     // dados estruturados específicos do tipo

  // Estado
  status       String   @default("pending") // "pending" | "accepted" | "snoozed" | "dismissed"
  snoozedUntil DateTime?
  resolvedAt   DateTime?

  // Referencias opcionais
  acaoId       String? // se a sugestao aponta pra uma AcaoPainel existente
  clienteId    String? // se aponta para um ClienteBackoffice
  eventoCalId  String? // id do evento na agenda (cowork cache)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, tipo])
}

// Sug 5 (Retrospectiva semanal): snapshot gerado todo domingo 20h Bahia com
// métricas da semana + insight textual pelo Claude. Card fixo no painel de 2ª
// até Eduardo dispensar.
model PainelRetrospectiva {
  id         String   @id @default(cuid())
  userId     String
  semanaInicio DateTime  // segunda-feira 00:00 Bahia
  semanaFim    DateTime  // domingo 23:59 Bahia

  // Metricas quantitativas (JSON com estrutura definida em types.ts)
  metricas   Json
  // Insight gerado pelo Claude (texto livre)
  insight    String   @db.Text

  dispensada  Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semanaInicio])
  @@index([userId, createdAt])
}

// Sug 4 (Triagem AI de e-mails): classificação de cada e-mail puxado do
// cache MS Mail. Alimenta o botao "Criar acao" com quadrante sugerido.
model PainelEmailAI {
  id         String   @id @default(cuid())
  userId     String
  externoId  String   // id do email no ms-mail
  remetente  String
  assunto    String
  snippet    String   @db.Text

  // Classificacao do Claude
  tipo              String   // "acao" | "fyi" | "spam" | "agendamento" | "cliente_novo"
  urgencia          String   // "alta" | "media" | "baixa"
  quadranteSugerido String?  // "Q1" | "Q2" | "Q3" | "Q4"
  tituloAcao        String?
  venceSugerido     DateTime?
  clienteVinculadoId String?

  // Estado
  processado      Boolean  @default(false) // virou AcaoPainel
  arquivado       Boolean  @default(false) // usuario ignorou
  acaoGeradaId    String?  // id da AcaoPainel criada

  classificadoEm DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externoId])
  @@index([userId, processado])
  @@index([userId, tipo])
}

// ============================================
// TIME — ORGANIZAÇÃO E PESSOAS (Fase 1)
// Fases futuras adicionarão: PAT, AcordoComercial, ReuniaoTime
// ============================================

model Filial {
  id        String   @id @default(cuid())
  nome      String   @unique
  cidade    String
  estado    String
  isMatriz  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pessoas Pessoa[]
}

model Departamento {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pessoas Pessoa[]
  equipes Equipe[]
}

model Equipe {
  id             String       @id @default(cuid())
  nome           String
  departamentoId String
  departamento   Departamento @relation(fields: [departamentoId], references: [id])
  liderId        String?
  lider          Pessoa?      @relation("EquipeLider", fields: [liderId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  pessoas Pessoa[]

  @@unique([nome, departamentoId])
  @@index([departamentoId])
}

model Pessoa {
  id String @id @default(cuid())

  // Identificação
  nomeCompleto   String
  apelido        String?
  cpf            String    @unique
  email          String    @unique
  telefone       String?
  dataNascimento DateTime?
  cidade         String?
  fotoUrl        String?

  // Vínculo Onix
  dataEntrada  DateTime  @default(now())
  dataSaida    DateTime?
  motivoSaida  String?   // "demissao" | "saida_voluntaria" | "fim_contrato" | "outro"
  status       String    @default("ativo") // "ativo" | "arquivado"
  cargoFamilia String    // "assessor_investimentos" | "socio" | "imobiliaria" | "corretora" | "qualidade" | "administrativo"
  cargoTitulo  String?
  teamRole     String    @default("colaborador") // "admin" | "lideranca" | "colaborador"
  observacoes  String?   @db.Text

  // Hierarquia organizacional
  filialId       String
  filial         Filial       @relation(fields: [filialId], references: [id])
  departamentoId String
  departamento   Departamento @relation(fields: [departamentoId], references: [id])
  equipeId       String?
  equipe         Equipe?      @relation(fields: [equipeId], references: [id])

  // A quem se reporta (self-relation)
  lideradoPorId String?
  lideradoPor   Pessoa?  @relation("HierarquiaPessoa", fields: [lideradoPorId], references: [id])
  lidera        Pessoa[] @relation("HierarquiaPessoa")

  // Equipes que lidera
  equipesLideradas Equipe[] @relation("EquipeLider")

  // Link opcional para User (auth) — pessoa pode existir antes do convite
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Fase 2 — Numerologia & Contratos
  numerologia            Numerologia?
  contratoSocialUploads  ContratoSocialUpload[]
  acordosComerciais      AcordoComercial[]
  conviteOnboarding      ConviteOnboarding?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([filialId, departamentoId])
  @@index([teamRole])
}

// ============================================
// TIME — NUMEROLOGIA (Fase 2A) — admin only
// ============================================

model Numerologia {
  id String @id @default(cuid())

  pessoaId String @unique
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  // Dados-fonte usados no cálculo (snapshot)
  nomeFonte     String
  dataNascFonte DateTime

  // Os 6 números Pitagóricos
  caminhoVida   Int
  expressao     Int
  alma          Int
  personalidade Int
  anoPessoal    Int
  anoPessoalRef Int

  karmicos      Int[] @default([])
  masterNumbers Int[] @default([])

  leitura String? @db.Text

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContratoSocialUpload {
  id String @id @default(cuid())

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  filename  String
  mimeType  String  @default("application/pdf")
  pdfBase64 String  @db.Text
  bytes     Int?

  nomeExtraido     String?
  cpfExtraido      String?
  dataNascExtraida DateTime?

  status        String @default("pendente") // "pendente" | "extraido" | "erro"
  erroMensagem  String?

  uploadedAt DateTime @default(now())

  @@index([pessoaId, uploadedAt])
}

// ============================================
// TIME — ACORDO COMERCIAL (Fase 2B)
// 100% restrito a admin para outros; pessoa vê o próprio histórico.
// Não há cálculo de repasse — apenas armazenamento estruturado + PDF.
// ============================================

model AcordoComercial {
  id String @id @default(cuid())

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  tipo            String  // "pro_labore" | "split" | "comissao" | "misto"
  regrasEspeciais String? @db.Text // texto livre — escala de split, gatilhos, bônus de meta

  // PDF do contrato assinado (opcional — pode ser registrado sem PDF inicialmente)
  contratoFilename String?
  contratoMimeType String? @default("application/pdf")
  contratoBase64   String? @db.Text
  contratoBytes    Int?

  // Vigência
  dataInicio DateTime  @default(now())
  dataFim    DateTime? // null = vigente

  observacoes String? @db.Text // notas internas (admin only)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([pessoaId, dataInicio])
  @@index([pessoaId, dataFim])
}

// ============================================
// TIME — CONVITE DE ONBOARDING (Fase 2C)
// Admin gera um link público com token; pessoa abre, define senha,
// vira User e ganha acesso ao Cockpit.
// ============================================

model ConviteOnboarding {
  id String @id @default(cuid())

  pessoaId String @unique // 1:1 — só 1 convite ativo por pessoa
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime? // null = ainda não consumido

  criadoEm DateTime @default(now())

  @@index([token])
}

