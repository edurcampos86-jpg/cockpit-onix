  clienteId String
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  titulo    String
  descricao String?   @db.Text
  prazoData DateTime?
  valorAlvo Float?
  status    String    @default("ativa") // "ativa" | "atingida" | "pausada" | "cancelada"
  categoria String? // "aposentadoria" | "educacao" | "imovel" | "viagem" | "outro"

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([clienteId])
}

// Eventos de vida (aniversários, casamentos, nascimentos)
model EventoVida {
  id        String            @id @default(cuid())
  clienteId String
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo       String // "aniversario" | "casamento" | "nascimento" | "formatura" | "outro"
  titulo     String
  data       DateTime
  recorrente Boolean  @default(false)
  lembrar    Boolean  @default(true)
  notas      String?  @db.Text

  criadoEm DateTime @default(now())

  @@index([data])
  @@index([clienteId])
}

// CRM de indicações (referrals)
model Indicacao {
  id String @id @default(cuid())

  // Quem indicou (cliente existente)
  indicadorId String?
  indicador   ClienteBackoffice? @relation("ClienteIndicador", fields: [indicadorId], references: [id])

  // Indicado (prospect)
  nomeIndicado     String
  emailIndicado    String?
  telefoneIndicado String?

  status               String  @default("recebida") // "recebida" | "contatada" | "reuniao" | "convertida" | "perdida"
  valorEstimado        Float?
  agradecimentoEnviado Boolean @default(false)
  notas                String? @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([status])
}

// Questionário de descoberta profunda (Storyselling — hemisfério direito)
model PerfilDescoberta {
