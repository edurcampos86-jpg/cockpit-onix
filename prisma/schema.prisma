  sonhos           String? @db.Text // o que faria se dinheiro não fosse problema
  legado           String? @db.Text // o que quer deixar para a próxima geração
  experienciaPrev  String? @db.Text // experiências passadas com investimentos
  linguagemPref    String? // "tecnica" | "simples" | "visual" | "narrativa"
  mentorReferencia String? @db.Text // quem o cliente admira financeiramente
  familiaSituacao  String? @db.Text // composição familiar e dependentes
  perguntaMagica   String? @db.Text // resposta à "se tudo desse certo, como seria daqui a 5 anos?"

  atualizadoEm DateTime @updatedAt
