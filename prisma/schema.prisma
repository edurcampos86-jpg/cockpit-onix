  objetivoPrincipal String? @db.Text
  horizonteAnos     Int?
  perfilRisco       String? // "conservador" | "moderado" | "arrojado"
  alocacaoAlvo      String? @db.Text // ex: "60% RF / 30% RV / 10% alternativos"
  riscosPrincipais  String? @db.Text
  proximosPassos    String? @db.Text
  resumoExecutivo   String? @db.Text

