generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

model User {
  id        String   @id @default(cuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  password  String
  role      String   @default("support") // "admin" | "support"
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts             Post[]
  scripts           Script[]
  tasks             Task[]
  leads             Lead[]
  prioridadesPainel PainelPrioridade[]
  acoesPainel       AcaoPainel[]
  cachesPainel      PainelCacheExterno[]
  syncRequests      SyncRequest[]
  painelSugestoes   PainelSugestao[]
  painelRetros      PainelRetrospectiva[]
  painelEmailsAI    PainelEmailAI[]
  pessoa            Pessoa?
  googleAuth        UserGoogleAuth?
  microsoftAuth     UserMicrosoftAuth?
  reunioesCliente   ReuniaoCliente[]

  // Jurídico — fase 1A
  contratosArquivosEnviados   ContratoArquivo[]  @relation("ContratoUploadedBy")
  contratosExtracoesRevisadas ContratoExtracao[] @relation("ContratoExtracaoRevisor")

  // Jurídico — fase 1B
  usuarioPermissao UsuarioPermissao?
  acessosContratos ContratoAcessoLog[]
}

// ============================================
// OAUTH POR USUÁRIO — Google (Calendar + Gmail)
// ============================================
// Tokens cifrados em AES-256-GCM (src/lib/crypto.ts).
// Padrão canônico per-user pós Fase 2: TODO acesso ao Google
// (Calendar + Gmail, leitura e escrita) passa por esta tabela.
// GOOGLE_REFRESH_TOKEN global foi removido.
model UserGoogleAuth {
  id                   String    @id @default(cuid())
  userId               String    @unique
  googleEmail          String
  refreshTokenEnc      String    @db.Text
  accessTokenEnc       String?   @db.Text
  accessTokenExpiresAt DateTime?
  scopes               String    @db.Text // CSV dos escopos concedidos
  connectedAt          DateTime  @default(now())
  lastUsedAt           DateTime?
  lastErrorAt          DateTime?
  lastError            String?   @db.Text
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// OAUTH POR USUÁRIO — Microsoft (Calendar + Mail via Graph)
// ============================================
// Espelha UserGoogleAuth. Convive com o fluxo cowork-sync legado
// (Chrome MCP scrape do Outlook Web → PainelCacheExterno) — o
// agregador prefere Graph quando UserMicrosoftAuth existe; senao cai
// no cache cowork. Refresh token MS tem validade de 90 dias (vs Google
// ~indefinido), entao re-consent eh mais frequente.
model UserMicrosoftAuth {
  id                   String    @id @default(cuid())
  userId               String    @unique
  microsoftEmail       String
  microsoftTenantId    String? // tenant da org (NULL para conta consumer)
  refreshTokenEnc      String    @db.Text
  accessTokenEnc       String?   @db.Text
  accessTokenExpiresAt DateTime?
  scopes               String    @db.Text // CSV dos escopos concedidos
  connectedAt          DateTime  @default(now())
  lastUsedAt           DateTime?
  lastErrorAt          DateTime?
  lastError            String?   @db.Text
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// CALENDÁRIO EDITORIAL E CONTEÚDO
// ============================================

model Post {
  id                    String    @id @default(cuid())
  title                 String
  format                String // "reel" | "story" | "carrossel"
  category              String // "pergunta_semana" | "onix_pratica" | "patrimonio_mimimi" | "alerta_patrimonial" | "sabado_bastidores"
  status                String    @default("rascunho") // "rascunho" | "roteiro_pronto" | "gravado" | "editado" | "agendado" | "publicado"
  scheduledDate         DateTime
  scheduledTime         String? // HH:mm
  publishedAt           DateTime?
  publishedUrl          String?
  ctaType               String? // "explicito" | "implicito" | "identificacao"
  hashtags              String? // comma-separated
  notes                 String?
  order                 Int       @default(0)
  googleCalendarEventId String? // ID do evento no Google Calendar
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  scriptId String? @unique
  script   Script? @relation(fields: [scriptId], references: [id])

  tasks Task[]
}

model Script {
  id            String   @id @default(cuid())
  title         String
  category      String
  hook          String?
  body          String
  cta           String?
  ctaType       String?
  estimatedTime String?
  hashtags      String?
  isTemplate    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  post     Post?
  versions ScriptVersion[]
}

model ScriptVersion {
  id            String   @id @default(cuid())
  title         String
  hook          String?
  body          String
  cta           String?
  ctaType       String?
  estimatedTime String?
  hashtags      String?
  changeReason  String   @default("edição manual")
  createdAt     DateTime @default(now())

  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

// ============================================
// GESTÃO DE TAREFAS
// ============================================

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pendente") // "pendente" | "em_progresso" | "concluida"
  priority    String    @default("media")
  dueDate     DateTime?
  completedAt DateTime?
  type        String    @default("geral")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assigneeId String
  assignee   User   @relation(fields: [assigneeId], references: [id])

  postId String?
  post   Post?   @relation(fields: [postId], references: [id])
}

// ============================================
// GESTÃO DE LEADS E FUNIL
// ============================================

model Lead {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  origin          String    @default("manychat")
  stage           String    @default("novo")
  temperature     String    @default("morno")
  productInterest String?
  notes           String?
  lastContactAt   DateTime?
  enteredAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  meetings Meeting[]
}

// ============================================
// ONIX CORRETORA - TREINAMENTO COMERCIAL
// ============================================

model Relatorio {
  id                  String   @id @default(cuid())
  vendedor            String
  periodo             String
  periodoInicio       DateTime
  periodoFim          DateTime
  dataExecucao        DateTime
  conversasAnalisadas Int
  pdfPath             String?
  secao1              String   @db.Text
  secao2              String   @db.Text
  secao3              String   @db.Text
  secao4              String   @db.Text
  secao5              String   @db.Text
  secao0              String?  @db.Text
  scriptSemana        String?  @db.Text
  termometro          String?  @db.Text
  retomada            String?  @db.Text
  acoes               Acao[]
  metricas            Metrica?
  createdAt           DateTime @default(now())

  @@index([vendedor])
  @@index([periodoInicio])
}

model Acao {
  id          String    @id @default(cuid())
  relatorioId String
  relatorio   Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)
  vendedor    String
  numero      Int
  titulo      String
  descricao   String    @db.Text
  concluida   Boolean   @default(false)
  concluidaEm DateTime?
  createdAt   DateTime  @default(now())

  @@index([relatorioId])
  @@index([vendedor, concluida])
}

model Metrica {
  id                   String    @id @default(cuid())
  relatorioId          String    @unique
  relatorio            Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)
  vendedor             String
  periodo              String
  conversasAnalisadas  Int
  conversasSemResposta Int       @default(0)
  reunioesAgendadas    Int       @default(0)
  leadsPerdidos        Int       @default(0)
  score                Int       @default(0)
  createdAt            DateTime  @default(now())

  @@index([vendedor, createdAt])
}

model RelatorioColetivo {
  id                   String   @id @default(cuid())
  periodo              String
  periodoInicio        DateTime
  periodoFim           DateTime
  dataExecucao         DateTime
  vendedoresAnalisados String // "Thiago Vergal,Rose Oliveira"
  metricasConsolidadas String?  @db.Text // JSON: totais + variações
  scoreIndividual      String?  @db.Text // JSON: scores por vendedor
  termometroTime       String?  @db.Text
  objecoesRecorrentes  String?  @db.Text
  padroesPositivos     String?  @db.Text
  padroesRisco         String?  @db.Text
  scriptColetivo       String?  @db.Text
  planoColetivo        String?  @db.Text
  cumprimentoAnterior  String?  @db.Text
  createdAt            DateTime @default(now())

  @@index([periodoInicio])
}

model Meta {
  id        String   @id @default(cuid())
  vendedor  String
  metrica   String // "conversas" | "reunioes" | "semResposta" | "perdidos" | "score"
  valor     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendedor, metrica])
}

// ============================================
// REUNIÕES E TRANSCRIÇÕES (Plaud.ai via Zapier)
// ============================================

model Meeting {
  id            String   @id @default(cuid())
  title         String
  date          DateTime
  duration      Int? // minutos
  participants  String? // nomes separados por vírgula
  vendedor      String? // vendedor da equipe Onix (Eduardo Campos | Thiago Vergal | Rose Oliveira)
  transcription String?  @db.Text // transcrição completa
  summary       String? // resumo gerado pela IA
  actionItems   String? // itens de ação extraídos (JSON)
  insights      String? // insights para roteiros (gerado pela Claude AI)
  source        String   @default("plaud") // "plaud" | "manual" | "zoom" | "teams"
  externalId    String? // ID do Plaud/Zapier
  audioUrl      String? // URL do áudio original
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  @@index([vendedor, date])
}

// ============================================
// CONFIGURAÇÕES DINÂMICAS (fallback p/ env vars)
// ============================================

model Config {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================
// ANALYTICS E FEEDBACK LOOP
// ============================================

model InstagramPost {
  id                  String    @id @default(cuid())
  instagramId         String    @unique
  type                String // "VIDEO" | "CAROUSEL_ALBUM" | "IMAGE"
  caption             String?
  permalink           String?
  pilar               String? // "P1" | "P2" | "P3" | "P4"
  formato             String? // "reel" | "carrossel" | "imagem" | "stories"
  ctaType             String? // "explicito" | "implicito" | "identificacao" | "algoritmo"
  tema                String? // tema central da semana
  likes               Int       @default(0)
  comments            Int       @default(0)
  shares              Int       @default(0)
  saved               Int       @default(0)
  reach               Int       @default(0)
  views               Int       @default(0)
  totalInteractions   Int       @default(0)
  engagementRate      Float     @default(0) // (totalInteractions / reach) * 100
  saveRate            Float     @default(0) // (saved / reach) * 100
  publishedAt         DateTime
  insightsCollectedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model WeeklyAnalysis {
  id             String   @id @default(cuid())
  weekStart      DateTime
  weekEnd        DateTime
  totalPosts     Int      @default(0)
  newFollowers   Int      @default(0)
  lostFollowers  Int      @default(0)
  totalFollowers Int      @default(0)
  metricas       String // JSON: métricas por pilar/formato/CTA
  descobertas    String // JSON: array de descobertas
  recomendacoes  String // JSON: array de recomendações
  proximosTemas  String? // JSON: temas sugeridos para próximas semanas
  geradoPor      String   @default("manual") // "automatico" | "manual"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  recommendations Recommendation[]
}

model Recommendation {
  id              String   @id @default(cuid())
  tipo            String // "pilar" | "formato" | "cta" | "horario" | "frequencia" | "tema"
  titulo          String
  descricao       String
  acao            String
  impactoEsperado String?
  prioridade      String   @default("media") // "alta" | "media" | "baixa"
  status          String   @default("pendente") // "pendente" | "implementada" | "descartada"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  weeklyAnalysisId String?
  weeklyAnalysis   WeeklyAnalysis? @relation(fields: [weeklyAnalysisId], references: [id])

  scriptAdjustments ScriptAdjustment[]
}

model ScriptAdjustment {
  id           String   @id @default(cuid())
  scriptId     String?
  ajuste       String // Descrição do ajuste feito
  motivacao    String // Por que foi feito
  statusAntes  String? // Conteúdo antes do ajuste
  statusDepois String? // Conteúdo depois do ajuste
  aplicado     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id])
}

// ============================================
// PAINEL SEMANAL — METAS E PIPELINE
// ============================================

model MetaMensal {
  id               String   @id @default(cuid())
  mes              Int // 1-12
  ano              Int
  metaFaturamento  Float // valor da meta mensal em R$
  faturamentoAtual Float    @default(0) // faturamento acumulado no mês
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  @@unique([mes, ano])
}

model NegocioPipeline {
  id              String            @id @default(cuid())
  nomeCliente     String
  valor           Float // valor do negócio em R$
  responsavel     String // nome do vendedor
  etapa           String // etapa no pipeline
  ultimaAtividade DateTime // data da última atividade registrada
  externalId      String?           @unique // ID no CRM Datacrazy (futura integração)
  ativo           Boolean           @default(true)
  motivoPerda     String? // "preco" | "timing" | "concorrencia" | "atendimento" | "outro"
  dataPerda       DateTime? // quando foi marcado como adormecido
  dataRecontato   DateTime? // agenda de recontato (dataPerda + 60 dias)
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt
  resolucoes      AlertaResolucao[]

  @@index([ativo, ultimaAtividade])
  @@index([etapa])
}

// ============================================
// ALERTAS DE PIPELINE
// ============================================

model AlertaResolucao {
  id          String          @id @default(cuid())
  negocioId   String
  negocio     NegocioPipeline @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  tipo        String // "parado_48h" | "alto_ticket" | "reativacao_60d"
  acaoTomada  String          @db.Text
  resolvidoEm DateTime        @default(now())

  @@index([negocioId])
}

// ============================================
// RITUAIS DE GESTÃO
// ============================================

model RitualExecucao {
  id        String   @id @default(cuid())
  ritualId  String // ID do ritual (micro-coaching, reuniao-segunda, etc.)
  data      DateTime // data da ocorrência
  realizado Boolean  @default(false)
  notas     String?  @db.Text
  criadoEm  DateTime @default(now())

  @@unique([ritualId, data])
  @@index([ritualId])
  @@index([data])
}

// ============================================
// BACKOFFICE — DADOS DE CLIENTES
// ============================================

// ============================================
// BACKOFFICE — CLIENTES (modelo Supernova 12-4-2)
// ============================================

model ClienteBackoffice {
  id          String @id @default(cuid())
  nome        String
  numeroConta String
  saldo       Float  @default(0)
  saldoConta  Float  @default(0) // Saldo em conta corrente (cash disponível) — via BTG

  // Classificação ABC (Supernova)
  // A = top clientes (12 contatos/ano), B = relacionamento ativo, C = manutenção
  classificacao       String  @default("C") // "A" | "B" | "C"
  classificacaoManual Boolean @default(false) // true = travada, não recalcular

  // Contato e relacionamento
  email       String?
  telefone    String?
  aniversario DateTime?
  profissao   String?
  nicho       String? // "medico" | "empresario" | "executivo" | "outro"

  // Endereço
  endereco    String?
  complemento String?
  cidade      String?
  estado      String? // UF, ex: "BAHIA", "SP"
  cep         String?

  // Dados pessoais (vindos da Base BTG / Informações)
  estadoCivil   String?
  genero        String?
  nacionalidade String?
  cpfConjuge    String?
  tipoConta     String? // "PF" | "PJ"

  // Storyselling / perfil emocional
  perfilEmocional String? @db.Text // medos, sonhos, linguagem preferida
  observacoes     String? @db.Text

  // Cadência e promessa de serviço
  ultimoContatoAt     DateTime? // qualquer canal (WhatsApp, ligação, reunião, manual)
  ultimaReuniaoAt     DateTime? // só reuniões (Plaud + manual tipo=reuniao)
  proximaReuniaoAt    DateTime? // próxima reunião agendada (Calendar / Datacrazy multiservice)
  proximoContatoAt    DateTime? // próximo contato planejado (qualquer canal)
  ultimaSyncDatacrazy DateTime? // quando rodou último sync de contatos (Datacrazy + Plaud)

  // Receita
  receitaAnual Float @default(0)

  // Dados BTG sincronizados via API
  cpfCnpj                     String? // taxIdentification do holder (CPF ou CNPJ)
  perfilInvestidor            String? // Suitability: "conservador" | "moderado" | "sofisticado"
  suitabilityValidoAte        DateTime? // Validade do perfil suitability
  tipoInvestidor              String? // "Qualificado" | "Sofisticado" | "Nao Qualificado"
  faixaCliente                String? // "Entre 300k e 500k", "Entre 5MM e 10MM", etc.
  ativacaoConta               String? // "Ativa" | "Bloqueio Total" | etc.
  pendenciaCadastral          String?
  dataAberturaConta           DateTime?
  dataUltimaRevisaoCadastral  DateTime?
  dataProximaRevisaoCadastral DateTime?
  idClienteBtg                String? // ID do cliente no BTG (campo "ID Cliente")
  tipoParceiro                String? // "AGENTE AUTONOMO" etc.
  escritorio                  String? // Nome do escritório do parceiro
  codigoEscritorio            String? // Código do escritório do parceiro
  assessorCge                 String? // CGE do assessor responsável (Relacionamento Conta×Parceiro)
  assessorNome                String? // Nome do assessor (cache pra exibir)
  assessorEmail               String? // Email do assessor (cache pra exibir)
  breakdownProdutos           Json? // Breakdown completo da posição BTG (renda fixa, fundos, equities, etc.)
  positionDate                DateTime? // Data da última posição BTG
  coHolders                   Json? // Co-titulares da conta
  usuariosBtg                 Json? // Lista de usuários da conta no BTG (nome, email, telefone, isOwner)
  ultimaSyncBtg               DateTime? // Quando foi a última sincronização BTG (qualquer endpoint)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interacoes       InteracaoCliente[]
  metas            MetaCliente[]
  eventosVida      EventoVida[]
  indicacoes       Indicacao[]           @relation("ClienteIndicador")
  perfilDescoberta PerfilDescoberta?
  planoUmaPagina   PlanoUmaPagina?
  checklist        ChecklistOrganizacao?
  acoesVinculadas  AcaoPainel[]          @relation("AcaoCliente")
  movimentacoesBtg MovimentacaoBtg[]
  conversas        Conversa[]
  gruposWhatsApp   GrupoCliente[]
  reunioes         ReuniaoCliente[]

  @@index([numeroConta])
  @@index([classificacao])
  @@index([proximoContatoAt])
  @@index([assessorCge])
  @@index([cpfCnpj])
  @@index([telefone])
}

// ============================================
// REUNIÕES — fonte unificada para próx/última reunião
// ============================================
// Cada linha = uma reunião agregada de UMA fonte externa.
// Mesma reunião replicada em 2 fontes (ex: criada no Outlook,
// sincronizada no Google Cal) gera 2 linhas com `source` diferente
// mas `startAt` igual — o cálculo dos agregados deduplica.
//
// `proximaReuniaoAt` e `ultimaReuniaoAt` em ClienteBackoffice viram
// CACHE derivado: recalculados via lib/reunioes.ts após cada upsert.
model ReuniaoCliente {
  id        String            @id @default(cuid())
  clienteId String
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  source     String // "google-cal" | "outlook-ics" | "datacrazy-atividade" | "manual"
  externalId String // event.id do Google, UID do ICS, activity.id do Datacrazy, cuid() pra manual

  // userId é o "dono" da reunião quando a fonte é per-user (google-cal pos
  // Fase 2; outlook futuramente). NULL para fontes globais legadas
  // (outlook-ics admin único, datacrazy-atividade) ate elas migrarem.
  // Permite que User A e User B tenham o MESMO event.id em seus calendários
  // sem colisão de unique constraint.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startAt DateTime
  endAt   DateTime?
  titulo  String?

  realizada Boolean @default(false) // true = passada/confirmada · false = futura/marcada

  matchedVia String // "email" | "telefone" | "nome-unico" | "nome-substring" | "manual"
  matchScore Int? // 100=email · 80=telefone · 50=nome-unico · 30=nome-substring · 0=manual

  rawPayload Json? // snapshot do evento pra debug

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dedupe escopado por usuario. NULL no userId vale para fontes globais
  // (Postgres permite múltiplos NULL no unique).
  @@unique([userId, source, externalId])
  @@index([clienteId, startAt])
  @@index([source, startAt])
  @@index([userId, source])
}

// ============================================
// MOVIMENTAÇÕES BTG (timeline financeira do cliente)
// ============================================

model MovimentacaoBtg {
  id        String            @id @default(cuid())
  clienteId String
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  numeroConta  String // redundante com cliente.numeroConta mas facilita debug
  data         DateTime // data da movimentação
  tipo         String // ex: "DEPÓSITO DE CUSTÓDIA", "RESGATE", "APLICAÇÃO", etc.
  descricao    String?  @db.Text // descrição livre vinda do BTG
  mercado      String? // ex: "RENDA_FIXA", "FUNDOS", "BOLSA", "PREVIDENCIA"
  ativo        String? // ex: "CDB BTG 120% CDI"
  valor        Float // valor bruto (grossValue)
  valorLiquido Float? // se BTG fornecer netValue separado
  hashUnico    String   @unique // hash data+conta+tipo+valor+ativo pra dedup

  payloadBruto Json? // snapshot completo da movimentação como veio do BTG (debug)
  createdAt    DateTime @default(now())

  @@index([clienteId, data])
  @@index([numeroConta])
  @@index([data])
  @@index([tipo])
}

// ============================================
// LOG DE EXECUÇÕES BTG (auditoria)
// ============================================

model BtgSyncLog {
  id                String    @id @default(cuid())
  tipo              String // "import" | "enrich" | "movements" | "webhook" | "balances"
  iniciado          DateTime  @default(now())
  finalizado        DateTime?
  sucesso           Boolean   @default(false)
  contasProcessadas Int       @default(0)
  contasComErro     Int       @default(0)
  resumo            String?   @db.Text
  erros             Json? // lista de erros { conta, motivo }
  trigger           String? // "manual" | "cron" | "webhook"
  userId            String? // quem disparou se foi manual

  @@index([tipo, iniciado])
  @@index([iniciado])
}

// Registro de cada contato: 12-4-2 (12 ligações, 4 reuniões, 2 revisões por ano para clientes A)
model InteracaoCliente {
  id        String            @id @default(cuid())
  clienteId String
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo       String // "ligacao" | "reuniao" | "revisao" | "email" | "whatsapp" | "evento"
  canal      String? // "telefone" | "presencial" | "videoconferencia" | "email" | "whatsapp"
  assunto    String
  resumo     String?  @db.Text
  data       DateTime @default(now())
  duracaoMin Int?

  // Roteiro RCA (Rapid Client Assessment)
  rcaNotas String? @db.Text

  criadoEm DateTime @default(now())

  @@index([clienteId, data])
  @@index([tipo])
}

// Mapa de metas de vida do cliente
model MetaCliente {
