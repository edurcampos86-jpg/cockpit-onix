  clienteId String            @unique
  cliente   ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  testamento             Boolean @default(false)
  seguroVida             Boolean @default(false)
  planoSucessao          Boolean @default(false)
  reservaEmergencia      Boolean @default(false)
  planoSaude             Boolean @default(false)
  procuracao             Boolean @default(false)
  inventarioBens         Boolean @default(false)
  beneficiariosAtual     Boolean @default(false)
  declaracaoIR           Boolean @default(false)
  planejamentoTributario Boolean @default(false)
  notas                  String? @db.Text

  atualizadoEm DateTime @updatedAt
  criadoEm     DateTime @default(now())
}

// Biblioteca de histórias/analogias para storyselling
model StoryAnalogia {
  id         String  @id @default(cuid())
  titulo     String
  categoria  String // "aposentadoria" | "sucessao" | "risco" | "diversificacao" | "inflacao" | "disciplina"
  analogia   String  @db.Text
  quandoUsar String? @db.Text
  tags       String? // comma-separated

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([categoria])
}

// Lançamentos de receita por parceiro/produto/cliente (importados via planilha BTG)
model ReceitaItem {
  id                 String   @id @default(cuid())
  data               DateTime
  faturamento        Float    @default(0)
  imposto            Float    @default(0)
  faturamentoLiquido Float    @default(0)
  assessor           String?
  parceiro           String?
  departamento       String?
  classificacao      String?
  categoria          String?
  produto            String?
  nomeCliente        String?
  loteId             String // identifica a importação (para limpar/refazer)
  hash               String?  @unique // dedupe: data+valores+parceiro+produto+cliente+assessor
  criadoEm           DateTime @default(now())

  @@index([data])
  @@index([parceiro])
  @@index([produto])
  @@index([nomeCliente])
  @@index([loteId])
}

// ============================================
// PAINEL DO DIA
// ============================================

// 3 prioridades manuais por dia (posicao 1|2|3)
model PainelPrioridade {
  id        String  @id @default(cuid())
  userId    String
  data      String // "YYYY-MM-DD" em America/Sao_Paulo
  posicao   Int // 1, 2 ou 3
  texto     String
  concluida Boolean @default(false)

  // Sug 1 (Boot do Dia): prioridade sugerida automaticamente pela heurística
  // noturna. Eduardo confirma/edita no painel.
  sugeridaPorBoot Boolean @default(false)
  bootMotivo      String? // ex: "cliente A sem contato ha 27 dias"

  // Sug 2 (Deep Work blocks): tempo estimado para a prioridade + id do bloco
  // de foco criado no calendario (Outlook/Google)
  tempoEstimadoMin   Int?
  focusBlockEventId  String? // id do evento no calendario externo
  focusBlockProvider String? // "google" | "ms-calendar" | "pending-cowork"
  focusBlockStart    DateTime?
  focusBlockEnd      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data, posicao])
  @@index([userId, data])
}

// Acoes unificadas do painel: local (ecossistema) + MS To Do + Priority Matrix
// Write-back bidirecional via cowork (Chrome MCP): pendingSync=true dispara
// aplicação na origem na próxima sincronia.
model AcaoPainel {
  id          String    @id @default(cuid())
  userId      String
  titulo      String
  concluida   Boolean   @default(false)
  vence       DateTime?
  importante  Boolean   @default(false)
  noMeuDia    Boolean   @default(false)
  quadrante   String? // "Q1" | "Q2" | "Q3" | "Q4" (só Priority Matrix)
  origem      String // "local" | "ms-todo" | "priority-matrix"
  externoId   String? // id na fonte externa (preenchido após sync)
  projetoPm   String? // nome do projeto no Priority Matrix
  pendingSync Boolean   @default(false)
  syncOp      String? // "create" | "update" | "delete"
  syncError   String?

  // Fecho de atividade (Sugestao 4: modal de encerramento)
  resultado          String?   @db.Text // o que foi entregue / nota livre
  tempoGastoMin      Int? // tempo gasto em minutos
  clienteVinculadoId String? // FK opcional para ClienteBackoffice
  concluidaEm        DateTime? // timestamp do fecho (distinto de updatedAt)
  registradaCrm      Boolean   @default(false) // true se virou InteracaoCliente

  // Sug 2 (Deep Work): tempo estimado para execução — alimenta auto-blocking
  tempoEstimadoMin Int?

  // Sug 4 (Triagem AI de e-mails): origem foi um e-mail classificado pela IA
  criadaDeEmailId String? // id do PainelEmailAI que gerou a acao

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  clienteVinculado ClienteBackoffice? @relation("AcaoCliente", fields: [clienteVinculadoId], references: [id], onDelete: SetNull)

  @@index([userId, concluida])
  @@index([userId, origem])
  @@index([userId, pendingSync])
  @@index([clienteVinculadoId])
}

// Cache de leitura das fontes externas sem write-back (Calendar + Mail).
// Um registro por (user, source) — payload é substituído a cada sync.
model PainelCacheExterno {
  id       String   @id @default(cuid())
  userId   String
  source   String // "ms-calendar" | "ms-mail"
  payload  Json
  syncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId])
}

// Fila de pedidos de sync do usuario pro cowork (Chrome MCP).
// O usuario aperta "Sincronizar" no painel -> cria um registro pending.
// Quando o Claude Code roda na maquina dele, checa a fila, processa,
// marca como done/error.
model SyncRequest {
  id          String    @id @default(cuid())
  userId      String
  sources     String // "all" | "microsoft" | "priority-matrix"
  status      String    @default("pending") // "pending" | "in-progress" | "done" | "error"
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  error       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, requestedAt])
}

// Sug 3 (Auto-encerramento): sugestões geradas por automação que aparecem
// como cards de ação rápida no painel. Ex.: "Encerrar reunião com Onix Corretora
// que terminou há 30min". Eduardo aceita, adia ou ignora.
model PainelSugestao {
  id        String  @id @default(cuid())
  userId    String
  tipo      String // "encerrar-reuniao" | "cliente-fora-cadencia" | "acao-zumbi"
  titulo    String
  descricao String? @db.Text
  payload   Json // dados estruturados específicos do tipo

  // Estado
  status       String    @default("pending") // "pending" | "accepted" | "snoozed" | "dismissed"
  snoozedUntil DateTime?
  resolvedAt   DateTime?

  // Referencias opcionais
  acaoId      String? // se a sugestao aponta pra uma AcaoPainel existente
  clienteId   String? // se aponta para um ClienteBackoffice
  eventoCalId String? // id do evento na agenda (cowork cache)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, tipo])
}

// Sug 5 (Retrospectiva semanal): snapshot gerado todo domingo 20h Bahia com
// métricas da semana + insight textual pelo Claude. Card fixo no painel de 2ª
// até Eduardo dispensar.
model PainelRetrospectiva {
  id           String   @id @default(cuid())
  userId       String
  semanaInicio DateTime // segunda-feira 00:00 Bahia
  semanaFim    DateTime // domingo 23:59 Bahia

  // Metricas quantitativas (JSON com estrutura definida em types.ts)
  metricas Json
  // Insight gerado pelo Claude (texto livre)
  insight  String @db.Text

  dispensada Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semanaInicio])
  @@index([userId, createdAt])
}

// Sug 4 (Triagem AI de e-mails): classificação de cada e-mail puxado do
// cache MS Mail. Alimenta o botao "Criar acao" com quadrante sugerido.
model PainelEmailAI {
  id        String @id @default(cuid())
  userId    String
  externoId String // id do email no ms-mail
  remetente String
  assunto   String
  snippet   String @db.Text

  // Classificacao do Claude
  tipo               String // "acao" | "fyi" | "spam" | "agendamento" | "cliente_novo"
  urgencia           String // "alta" | "media" | "baixa"
  quadranteSugerido  String? // "Q1" | "Q2" | "Q3" | "Q4"
  tituloAcao         String?
  venceSugerido      DateTime?
  clienteVinculadoId String?

  // Estado
  processado   Boolean @default(false) // virou AcaoPainel
  arquivado    Boolean @default(false) // usuario ignorou
  acaoGeradaId String? // id da AcaoPainel criada

  classificadoEm DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externoId])
  @@index([userId, processado])
  @@index([userId, tipo])
}

// ============================================
// TIME — ORGANIZAÇÃO E PESSOAS (Fase 1)
// Fases futuras adicionarão: PAT, AcordoComercial, ReuniaoTime
// ============================================

model Filial {
  id        String   @id @default(cuid())
  nome      String   @unique
  cidade    String
  estado    String
  isMatriz  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pessoas Pessoa[]
}

model Departamento {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pessoas Pessoa[]
  equipes Equipe[]
}

model Equipe {
  id             String       @id @default(cuid())
  nome           String
  departamentoId String
  departamento   Departamento @relation(fields: [departamentoId], references: [id])
  liderId        String?
  lider          Pessoa?      @relation("EquipeLider", fields: [liderId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  pessoas Pessoa[]

  @@unique([nome, departamentoId])
  @@index([departamentoId])
}

model Pessoa {
  id String @id @default(cuid())

  // Identificação
  nomeCompleto   String
  apelido        String?
  cpf            String    @unique
  email          String    @unique
  telefone       String?
  dataNascimento DateTime?
  cidade         String?
  fotoUrl        String?

  // Vínculo Onix
  dataEntrada  DateTime  @default(now())
  dataSaida    DateTime?
  motivoSaida  String? // "demissao" | "saida_voluntaria" | "fim_contrato" | "outro"
  status       String    @default("ativo") // "ativo" | "arquivado"
  cargoFamilia String // "assessor_investimentos" | "socio" | "imobiliaria" | "corretora" | "qualidade" | "administrativo"
  cargoTitulo  String?
  teamRole     String    @default("colaborador") // "admin" | "lideranca" | "colaborador"
  observacoes  String?   @db.Text

  // Hierarquia organizacional
  filialId       String
  filial         Filial       @relation(fields: [filialId], references: [id])
  departamentoId String
  departamento   Departamento @relation(fields: [departamentoId], references: [id])
  equipeId       String?
  equipe         Equipe?      @relation(fields: [equipeId], references: [id])

  // A quem se reporta (self-relation)
  lideradoPorId String?
  lideradoPor   Pessoa?  @relation("HierarquiaPessoa", fields: [lideradoPorId], references: [id])
  lidera        Pessoa[] @relation("HierarquiaPessoa")

  // Equipes que lidera
  equipesLideradas Equipe[] @relation("EquipeLider")

  // Link opcional para User (auth) — pessoa pode existir antes do convite
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Fase 2 — Numerologia & Contratos
  numerologia           Numerologia?
  contratoSocialUploads ContratoSocialUpload[]
  acordosComerciais     AcordoComercial[]
  conviteOnboarding     ConviteOnboarding?

  // Fase 3 — PAT (perfil comportamental Criativa Humana)
  pats Pat[]

  // Fase 4 — Reuniões do time (timeline tipo CRM)
  participacoesReuniao ReuniaoTimeParticipante[]

  // Jurídico — fase 1A (contratos no B2)
  contratosArquivos ContratoArquivo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([filialId, departamentoId])
  @@index([teamRole])
}

// ============================================
// TIME — NUMEROLOGIA (Fase 2A) — admin only
// ============================================

model Numerologia {
  id String @id @default(cuid())

  pessoaId String @unique
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  // Dados-fonte usados no cálculo (snapshot)
  nomeFonte     String
  dataNascFonte DateTime

  // Os 6 números Pitagóricos
  caminhoVida   Int
  expressao     Int
  alma          Int
  personalidade Int
  anoPessoal    Int
  anoPessoalRef Int

  karmicos      Int[] @default([])
  masterNumbers Int[] @default([])

  leitura String? @db.Text

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContratoSocialUpload {
  id String @id @default(cuid())

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  filename  String
  mimeType  String @default("application/pdf")
  pdfBase64 String @db.Text
  bytes     Int?

  nomeExtraido     String?
  cpfExtraido      String?
  dataNascExtraida DateTime?

  status       String  @default("pendente") // "pendente" | "extraido" | "erro"
  erroMensagem String?

  uploadedAt DateTime @default(now())

  @@index([pessoaId, uploadedAt])
}

// ============================================
// TIME — ACORDO COMERCIAL (Fase 2B)
// 100% restrito a admin para outros; pessoa vê o próprio histórico.
// Não há cálculo de repasse — apenas armazenamento estruturado + PDF.
// ============================================

model AcordoComercial {
  id String @id @default(cuid())

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  tipo            String // "pro_labore" | "split" | "comissao" | "misto"
  regrasEspeciais String? @db.Text // texto livre — escala de split, gatilhos, bônus de meta

  // PDF do contrato assinado (opcional — pode ser registrado sem PDF inicialmente)
  contratoFilename String?
  contratoMimeType String? @default("application/pdf")
  contratoBase64   String? @db.Text
  contratoBytes    Int?

  // Vigência
  dataInicio DateTime  @default(now())
  dataFim    DateTime? // null = vigente

  observacoes String? @db.Text // notas internas (admin only)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Jurídico — fase 1A. Quando o PDF migra pro B2 via ContratoArquivo,
  // os campos contratoBase64/contratoBytes acima ficam vazios e a referência
  // passa por aqui. Mantemos os 4 campos legacy enquanto a migração não roda
  // em todo o passivo.
  contratoArquivo ContratoArquivo? @relation("AcordoComercialContrato")

  @@index([pessoaId, dataInicio])
  @@index([pessoaId, dataFim])
}

// ============================================
// TIME — CONVITE DE ONBOARDING (Fase 2C)
// Admin gera um link público com token; pessoa abre, define senha,
// vira User e ganha acesso ao Cockpit.
// ============================================

model ConviteOnboarding {
  id String @id @default(cuid())

  pessoaId String @unique // 1:1 — só 1 convite ativo por pessoa
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime? // null = ainda não consumido

  criadoEm DateTime @default(now())

  @@index([token])
}

// ============================================
// TIME — PAT / PERFIL DE ADEQUAÇÃO DE TRABALHO (Fase 3)
// Instrumento da Criativa Humana (criativahumana.com.br).
// Cada pessoa tem N PATs ao longo do tempo (refazer anualmente).
// Permissão: admin + a própria pessoa (liderança NÃO vê).
// ============================================

model Pat {
  id String @id @default(cuid())

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  // PDF original
  filename  String?
  pdfBase64 String? @db.Text // PDF em base64
  bytes     Int?

  // Quando o PAT foi aplicado (informado pelo PDF)
  dataPat DateTime

  // ── Campos resumo (extraídos pra busca/filtro/UI rápida) ──
  perspectiva    String? // "Baixa" | "Média" | "Alta"
  ambienteCelula Int? // 1-25 (posição na matriz)
  ambienteNome   String? // "Crescimento" | "Estabilidade" | "Sustentação" | etc
  orientacao     String? // "Social" | "Técnico" (lado predominante)
  aproveitamento String? // "Subaproveitado" | "Bem Aproveitado" | "Sobreaproveitado"

  // Top 3 competências estratégicas (em ordem de relevância)
  principaisCompetencias String[] @default([])

  // Tags/características em palavras-chave
  caracteristicas String[] @default([])

  // ── Dados estruturados completos (JSON — formatos definidos pelo parser) ──
  estrutural               Json? // { spread, suporteEstrutural, perspectivaNum, aproveitamento, cicloAlerta }
  iconeEstrutural          Json? // { analiseAprendizagem: {tipo, valor, intensidade}, ... × 6 dimensões }
  tendencias               Json? // { foco: 18, orientacao: 81, acao, conexao, relacionamento, regras, suportePressao }
  risco                    Json? // { estrutural, interno, atual, cicloAlerta, competencias: [{nome, potencial, esforco, comportamento}] }
  competenciasEstrategicas Json? // [{ nome, potencial, esforco, comportamento }, ...] × 17
  ambiente                 Json? // { celula, nome, desafios, habilidades, percepcao, caracteristicas, orientacoes, recomendacoes }

  // ── Blocos narrativos (textos longos do PDF) ──
  resumido  String? @db.Text // "Rápida descrição de habilidades"
  detalhado String? @db.Text // bloco DETALHADO em markdown
  sugestoes String? @db.Text // "Sugestões para desenvolvimento pessoal"
  gerencial String? @db.Text // bloco GERENCIAL em markdown

  // ── Status do parsing ──
  status       String  @default("pendente") // "pendente" | "extraido" | "erro"
  erroMensagem String?

  // ── Campos textuais que o ADMIN escreve (não vêm do PDF) ──
  pontosFortes      String? @db.Text
  pontosAtencao     String? @db.Text
  estiloComunicacao String? @db.Text

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pessoaId, dataPat])
  @@index([pessoaId, uploadedAt])
}

// ============================================
// TIME — REUNIÕES 1:1 / DE EQUIPE (Fase 4)
// Admin sobe PDF da ata; Claude extrai resumo + proximos passos.
// Permissao: admin ve todas, pessoa ve apenas as que ela participou.
// Existe um model Meeting separado (alimentado por Plaud) — este e' especifico
// pro modulo de gestao do TIME (1:1, feedback, comite, etc.).
// ============================================

model ReuniaoTime {
  id String @id @default(cuid())

  data      DateTime
  titulo    String? // descritivo (ex.: "1:1 com João — Q2 review")
  categoria String // "1_1_acompanhamento" | "feedback" | "avaliacao" | "alinhamento_metas" | "conversa_dificil" | "equipe" | "comite" | "outra"

  // PDF da ata original (opcional — admin pode digitar manualmente)
  filename  String?
  pdfBase64 String? @db.Text
  bytes     Int?

  // Conteudo
  transcricao    String? @db.Text // texto bruto (se admin colar manualmente)
  resumo         String? @db.Text // gerado pela IA OU digitado
  proximosPassos Json? // [{ texto, concluido: bool, concluidoEm: ISO|null }]

  // Quem criou (admin)
  criadoPorUserId String?

  // Status
  status       String  @default("pendente") // "pendente" | "extraido" | "erro" | "manual"
  erroMensagem String?

  observacoes String? @db.Text // notas livres do admin

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  participantes ReuniaoTimeParticipante[]

  @@index([data])
  @@index([categoria, data])
}

model ReuniaoTimeParticipante {
  reuniaoId String
  reuniao   ReuniaoTime @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)

  pessoaId String
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@id([reuniaoId, pessoaId])
  @@index([pessoaId])
}

// ============================================
// DATACRAZY — CONVERSAS WHATSAPP EM TEMPO REAL
// ============================================
model Conversa {
  id         String             @id @default(cuid())
  externalId String             @unique
  clienteId  String?
  cliente    ClienteBackoffice? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  instanceId   String
  contactPhone String?
  contactName  String?

  lastMessageAt DateTime?
  unmatched     Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens Mensagem[]

  @@index([clienteId, lastMessageAt])
  @@index([contactPhone])
  @@index([unmatched, lastMessageAt])
}

model Mensagem {
  id         String   @id @default(cuid())
  externalId String   @unique
  conversaId String
  conversa   Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  fromMe   Boolean
  tipo     String
  body     String? @db.Text
  mediaUrl String?

  sentAt     DateTime
  rawPayload Json?
  recebidoEm DateTime @default(now())

  @@index([conversaId, sentAt])
}

// Mapeamento manual de grupos WhatsApp Datacrazy → ClienteBackoffice.
//
// A API Datacrazy não expõe quem enviou cada mensagem em grupo (campos
// `contact`/`fromMe`/`author` vêm null/undefined). Como o assessor
// conversa com vários clientes via grupo dedicado (ex: "Rodrigo Magarão
// — Onix Capital"), precisamos saber a quem o grupo se refere.
//
// Eduardo cria o vínculo uma vez via UI/endpoint admin e o cron passa a
// atualizar `cliente.ultimoContatoAt` toda vez que o grupo tem mensagem
// nova. Mantém o invariante "matching nunca só por nome": o usuário
// confirma explicitamente.
model GrupoCliente {
  id              String            @id @default(cuid())
  groupExternalId String            @unique // id interno da conversa Datacrazy do grupo
  clienteId       String
  cliente         ClienteBackoffice @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  instanceId      String
  nomeGrupo       String? // cache pra exibir sem ir buscar na Datacrazy
  criadoEm        DateTime          @default(now())

  @@index([clienteId])
  @@index([instanceId])
}

// ============================================
// JURÍDICO — FASE 1A
// Cofre de contratos PDFs no Backblaze B2 + extração estruturada via Claude.
// Fase 1B adiciona RBAC, 2FA, watermark e audit log.
// Fase 1C adiciona backup + import em lote do passivo OneDrive.
// ============================================

model ContratoArquivo {
  id String @id @default(cuid())

  // Vínculo opcional com Pessoa do time (pode entrar sem vínculo e ser
  // pareado depois durante a revisão da extração).
  pessoaId String?
  pessoa   Pessoa? @relation(fields: [pessoaId], references: [id], onDelete: SetNull)

  // Identidade do arquivo
  nomeOriginal String
  mimeType     String @default("application/pdf")
  tamanhoBytes BigInt

  // Backblaze B2 (S3-compatible). Key segue o padrão:
  //   - pendentes-revisao/<cuid>.pdf  enquanto status = PENDENTE_REVISAO
  //   - pessoas/<pessoaId>/<cuid>.pdf após APROVADO
  b2Bucket String  @default("onix-cockpit-contratos")
  b2Key    String  @unique
  b2ETag   String? // ETag retornado pelo B2 (opcional, pra integridade)

  // Hash SHA-256 do conteúdo bruto, antes de qualquer transformação.
  // Único: mesma chave nunca é armazenada 2x — endpoint upload retorna 409
  // com o ID existente em vez de criar duplicata.
  hashSha256 String @unique

  // Auditoria de upload (audit log completo vem na fase 1B)
  uploadedById String
  uploadedBy   User     @relation("ContratoUploadedBy", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  // Estado e proveniência
  status           String  @default("pendente_revisao") // "pendente_revisao" | "aprovado" | "arquivado" | "rejeitado"
  origemImportacao String  @default("manual") // "manual" | "bulk_juridico" | "onedrive_legado" | "migracao_acordo"
  observacoes      String? @db.Text

  // Vínculo opcional com AcordoComercial após aprovação (1 contrato pode
  // gerar 1 acordo; acordo existente pode ser anexado de volta a um contrato).
  acordoComercialId String?          @unique
  acordoComercial   AcordoComercial? @relation("AcordoComercialContrato", fields: [acordoComercialId], references: [id], onDelete: SetNull)

  extracoes ContratoExtracao[]
  acessos   ContratoAcessoLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pessoaId])
  @@index([status])
  @@index([uploadedAt(sort: Desc)])
}

model ContratoExtracao {
  id String @id @default(cuid())

  contratoArquivoId String
  contratoArquivo   ContratoArquivo @relation(fields: [contratoArquivoId], references: [id], onDelete: Cascade)

  // Resultado bruto do Claude (JSON estruturado segundo PARSER_CONTRATO_PROMPT_V1)
  modeloIa       String   @default("claude-opus-4-7")
  promptVersion  String   @default("v1")
  confianca      Float // 0.00 a 1.00 — reportada pelo modelo
  dadosExtraidos Json // o JSON inteiro retornado
  erroExtracao   String?  @db.Text // se a chamada falhou ou JSON inválido
  extraidoEm     DateTime @default(now())

  // Revisão humana
  statusRevisao      String    @default("nao_revisado") // "nao_revisado" | "aprovado" | "corrigido" | "rejeitado"
  revisadoPorId      String?
  revisadoPor        User?     @relation("ContratoExtracaoRevisor", fields: [revisadoPorId], references: [id])
  revisadoEm         DateTime?
  dadosCorrigidos    Json? // overrides aplicados pelo revisor (mantém dadosExtraidos intacto)
  observacoesRevisao String?   @db.Text

  @@index([contratoArquivoId])
  @@index([statusRevisao])
  @@index([extraidoEm(sort: Desc)])
}

// ============================================
// JURÍDICO — FASE 1B (RBAC + 2FA + AUDIT LOG)
// ============================================

// Permissionamento granular por User. Vive em 1:1 com User. Se não existe
// registro, defaults conservadores aplicam-se via lib/auth/permissions.ts
// (negar tudo até admin liberar).
model UsuarioPermissao {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Permissões granulares pro módulo Jurídico.
  // Outros módulos podem reusar essa tabela no futuro com novos booleans.
  podeVerContratos     Boolean @default(false)
  podeBaixarContratos  Boolean @default(false)
  podeEditarContratos  Boolean @default(false)
  podeAprovarContratos Boolean @default(false)

  // Restrição por "carteira" (pessoaId). Valores:
  //  - "*"           → todas as pessoas (sócio/admin)
  //  - string[]      → apenas pessoaIds da lista (atendente vê só sua carteira)
  carteirasPermitidas Json @default("[]")

  // 2FA (TOTP). twoFactorSecret cifrado via lib/crypto.ts (AES-256-GCM).
  // backupCodes: array de strings já hashadas (bcrypt) para uso único.
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecretEnc   String?
  twoFactorBackupCodes Json? // string[] de hashes bcrypt
  twoFactorVerifiedAt  DateTime? // última vez que o usuário passou pelo verify

  atualizadoEm DateTime @updatedAt

  @@index([twoFactorEnabled])
}

// Audit log de TODA ação relevante sobre contratos. Imutável após criar.
// Visualizações, downloads, tentativas de impressão, aprovações, rejeições,
// edições de extração. Sem exceção — nem o admin escapa do log.
model ContratoAcessoLog {
  id String @id @default(cuid())

  contratoArquivoId String
  contratoArquivo   ContratoArquivo @relation(fields: [contratoArquivoId], references: [id], onDelete: Cascade)

  usuarioId String
  usuario   User   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  acao      String // "visualizou" | "tentou_baixar" | "tentou_imprimir" | "extraiu_dados" | "editou_extracao" | "aprovou" | "rejeitou" | "reextraiu"
  ipAddress String?
  userAgent String? @db.Text
  metadata  Json? // payload extra (página acessada, motivo, etc)

  timestamp DateTime @default(now())

  @@index([contratoArquivoId, timestamp(sort: Desc)])
  @@index([usuarioId, timestamp(sort: Desc)])
  @@index([acao, timestamp(sort: Desc)])
}

// ============================================
// JURÍDICO — FASE 1C (BACKUP + BULK IMPORT)
// ============================================

// Histórico de execuções de backup (Postgres dumps + restore tests).
// Cada run cria 1 linha — successo ou falha.
model BackupExecucao {
  id String @id @default(cuid())

  tipo            String // "banco" | "arquivos" | "completo" | "restore_test"
  destino         String // ex: b2://onix-cockpit-backups/postgres/2026/05/postgres-...sql.gz
  tamanhoBytes    BigInt?
  sucesso         Boolean
  erro            String? @db.Text
  duracaoSegundos Int?

  // Metadados (versão do schema, contagem de tabelas, etc)
  metadata Json?

  executadoEm DateTime @default(now())

  @@index([tipo, executadoEm(sort: Desc)])
  @@index([executadoEm(sort: Desc)])
}

// Job de importação em lote (ZIP do OneDrive 5.Jurídico).
// Cada arquivo importado vira um ContratoArquivo (status pendente_revisao);
// a ImportJob serve só pra progress tracking e auditoria.
model ImportJob {
  id String @id @default(cuid())

  tipo          String @default("juridico_zip") // "juridico_zip" | (outros tipos no futuro)
  totalArquivos Int    @default(0)
  processados   Int    @default(0)
  sucessos      Int    @default(0)
  erros         Int    @default(0)
  pulados       Int    @default(0) // duplicatas por hash
  status        String @default("running") // "running" | "completed" | "failed"

  iniciadoPorId   String
  zipFilename     String?
  zipBytes        BigInt?
  duracaoSegundos Int?

  detalhes Json? // array com status por arquivo processado

  iniciadoEm   DateTime  @default(now())
  finalizadoEm DateTime?

  @@index([iniciadoPorId, iniciadoEm(sort: Desc)])
  @@index([status])
}
